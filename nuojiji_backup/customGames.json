[{"title":"心动挑战成人版","description":"","icon":"🔥","coverColor":"#9F7AEA","htmlContent":"<!DOCTYPE html>\n<html lang=\"zh\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover\">\n  <title>谁先心动谁就输</title>\n  <style>\n    *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}\n    :root{\n      --bg:#1a1118;--bg2:#241c22;--card:#2a2028;--card-border:#3d2e38;\n      --text:#e8d8e0;--text2:#a08898;--text3:#705868;\n      --pink:#c4587a;--pink2:#e06888;--pink-bg:rgba(196,88,122,0.12);\n      --pink-border:rgba(196,88,122,0.3);\n      --narr:#2e2028;--narr-border:#4a3040;--narr-text:#d4a8b8;\n    }\n    html,body{width:100vw;height:100vh;overflow:hidden;background:var(--bg);color:var(--text);\n      font-family:system-ui,-apple-system,sans-serif;-webkit-user-select:none;user-select:none}\n    #app{width:100%;height:100%;display:flex;flex-direction:column;\n      padding-top:max(100px,env(safe-area-inset-top,0px));padding-bottom:env(safe-area-inset-bottom,16px)}\n    .top-bar{display:flex;align-items:center;gap:6px;padding:8px 12px;\n      background:var(--card);border-bottom:1px solid var(--card-border);flex-shrink:0}\n    .p-block{display:flex;align-items:center;gap:6px;flex:1;min-width:0}\n    .p-block.right{flex-direction:row-reverse;text-align:right}\n    .p-av{width:30px;height:30px;border-radius:50%;background:var(--bg2);overflow:hidden;\n      display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;\n      border:2px solid var(--card-border)}\n    .p-av img{width:100%;height:100%;object-fit:cover}\n    .p-info{min-width:0}\n    .p-name{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n    .p-hb{display:flex;align-items:center;gap:2px}\n    .p-hb-icon{font-size:13px;color:var(--pink2);animation:hb 0.85s infinite}\n    @keyframes hb{0%,100%{transform:scale(1)}50%{transform:scale(1.25)}}\n    .p-hb-num{font-size:12px;font-weight:700;color:var(--pink2)}\n    .vs{font-size:11px;color:var(--text3);font-weight:700;flex-shrink:0}\n    .round-badge{font-size:10px;color:#fff;background:var(--pink);padding:2px 8px;\n      border-radius:10px;flex-shrink:0;font-weight:700}\n    .top-btns{display:flex;gap:3px;flex-shrink:0}\n    .top-btn{width:28px;height:28px;border-radius:50%;background:var(--bg2);border:1px solid var(--card-border);\n      display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;color:var(--text2)}\n    .chat{flex:1;overflow-y:auto;padding:10px 14px;display:flex;flex-direction:column;gap:8px}\n    .chat::-webkit-scrollbar{width:3px}\n    .chat::-webkit-scrollbar-thumb{background:var(--card-border);border-radius:2px}\n    .sys{text-align:center;font-size:11px;color:var(--text3);padding:2px 0}\n    .narr{max-width:94%;align-self:center;width:100%;\n      background:var(--narr);border:1px solid var(--narr-border);border-radius:14px;\n      padding:12px 16px;font-size:13.5px;line-height:1.7;color:var(--narr-text);\n      white-space:pre-wrap;word-break:break-word;font-style:italic}\n    .ch-msg{align-self:center;max-width:94%;width:100%}\n    .ch-card{background:var(--card);border:1.5px solid var(--pink-border);border-radius:14px;\n      padding:14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.2)}\n    .ch-who{font-size:10px;color:var(--text3);margin-bottom:4px}\n    .ch-title{font-size:14px;font-weight:700;color:var(--pink2);margin-bottom:10px}\n    .ch-opts{display:flex;flex-direction:column;gap:6px}\n    .ch-opt{padding:10px 14px;border:1.5px solid var(--card-border);border-radius:12px;\n      background:var(--bg2);color:var(--text);font-size:13px;font-weight:600;cursor:pointer;\n      text-align:left;transition:.15s}\n    .ch-opt:active{border-color:var(--pink);background:var(--pink-bg)}\n    .ch-done{margin-top:8px;padding-top:8px;border-top:1px solid var(--card-border);\n      font-size:12px;color:var(--text2)}\n    .ch-loading{font-size:12px;color:var(--text3);padding:16px 0}\n    .hb-line{text-align:center;font-size:11px;color:var(--text3);padding:2px 0}\n    .hb-line b{color:var(--pink2)}\n    .res-box{background:var(--card);border:2px solid var(--pink);border-radius:16px;\n      padding:20px;text-align:center;box-shadow:0 4px 20px rgba(196,88,122,0.2);\n      max-width:94%;align-self:center;width:100%}\n    .res-icon{font-size:40px;margin-bottom:8px}\n    .res-title{font-size:18px;font-weight:800;color:var(--pink2);margin-bottom:4px}\n    .res-sub{font-size:13px;color:var(--text2);margin-bottom:4px}\n    .res-scores{display:flex;justify-content:center;gap:24px;margin:10px 0}\n    .res-p{text-align:center}\n    .res-p-name{font-size:11px;color:var(--text3)}\n    .res-p-hb{font-size:20px;font-weight:800;color:var(--pink2)}\n    .res-p-tag{font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px;margin-top:2px;display:inline-block}\n    .res-p-tag.w{background:rgba(74,222,128,0.15);color:#6ee7a0}\n    .res-p-tag.l{background:rgba(248,113,113,0.15);color:#fca5a5}\n    .res-btns{display:flex;gap:8px;justify-content:center;margin-top:12px}\n    .rbtn{padding:9px 20px;border:none;border-radius:20px;font-size:13px;font-weight:700;color:#fff;cursor:pointer}\n    .rbtn:active{transform:scale(0.95)}\n    .rbtn-pink{background:var(--pink)}\n    .rbtn-gray{background:var(--text3)}\n    .typing{font-size:12px;color:var(--text3);padding:3px 14px;flex-shrink:0;min-height:18px}\n    .start-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;\n      align-items:center;justify-content:center;z-index:100}\n    .start-overlay.hidden{display:none}\n    .start-box{background:var(--card);border-radius:20px;padding:28px 24px;text-align:center;\n      max-width:360px;width:92%;box-shadow:0 8px 32px rgba(0,0,0,0.3);border:1px solid var(--card-border)}\n    .start-box h2{font-size:22px;margin-bottom:4px;color:var(--pink2)}\n    .start-sub{font-size:12px;color:var(--text2);margin-bottom:14px;line-height:1.5}\n    .start-avs{display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:14px}\n    .start-av{width:52px;height:52px;border-radius:50%;background:var(--bg2);overflow:hidden;\n      display:flex;align-items:center;justify-content:center;font-size:24px;border:2px solid var(--card-border)}\n    .start-av img{width:100%;height:100%;object-fit:cover}\n    .s-cn{font-size:14px;font-weight:700;margin-bottom:14px;color:var(--pink2)}\n    .pick-btn{padding:12px;border:2px dashed var(--card-border);border-radius:14px;background:transparent;\n      color:var(--text2);font-size:14px;cursor:pointer;width:100%;margin-bottom:10px}\n    .pick-btn:active{border-color:var(--pink);color:var(--pink2)}\n    .go-btn{padding:14px;background:linear-gradient(135deg,var(--pink),#a04060);border:none;border-radius:24px;font-size:16px;\n      font-weight:700;color:#fff;cursor:pointer;width:100%;display:none;box-shadow:0 4px 16px rgba(196,88,122,0.3)}\n    .go-btn.show{display:block}\n    .go-btn:active{transform:scale(0.97)}\n  </style>\n</head>\n<body>\n<div id=\"app\">\n  <div class=\"top-bar\">\n    <div class=\"p-block\">\n      <div class=\"p-av\" id=\"t-u-av\">😊</div>\n      <div class=\"p-info\">\n        <div class=\"p-name\" id=\"t-u-name\">你</div>\n        <div class=\"p-hb\"><span class=\"p-hb-icon\" id=\"u-hb-i\">💗</span><span class=\"p-hb-num\" id=\"u-hb-n\">60</span></div>\n      </div>\n    </div>\n    <div class=\"vs\">VS</div>\n    <div class=\"round-badge\" id=\"r-badge\">0/5</div>\n    <div class=\"vs\">VS</div>\n    <div class=\"p-block right\">\n      <div class=\"p-av\" id=\"t-c-av\">?</div>\n      <div class=\"p-info\">\n        <div class=\"p-name\" id=\"t-c-name\">角色</div>\n        <div class=\"p-hb\"><span class=\"p-hb-icon\" id=\"c-hb-i\">💗</span><span class=\"p-hb-num\" id=\"c-hb-n\">60</span></div>\n      </div>\n    </div>\n    <div class=\"top-btns\">\n      <button class=\"top-btn\" onclick=\"doShare()\">📤</button>\n      <button class=\"top-btn\" onclick=\"showStart()\">🔄</button>\n    </div>\n  </div>\n  <div class=\"chat\" id=\"chat\"></div>\n  <div class=\"typing\" id=\"typing\"></div>\n</div>\n\n<div class=\"start-overlay\" id=\"start-overlay\">\n  <div class=\"start-box\">\n    <h2>💕 谁先心动谁就输</h2>\n    <div class=\"start-sub\">5轮大冒险对决<br>每轮AI出三个选项你来选<br>心跳更高的人输！</div>\n    <div class=\"start-avs\">\n      <div class=\"start-av\" id=\"s-u-av\">😊</div>\n      <div style=\"font-size:20px;color:var(--text3)\">💕</div>\n      <div class=\"start-av\" id=\"s-c-av\">?</div>\n    </div>\n    <div class=\"s-cn\" id=\"s-cn\"></div>\n    <button class=\"pick-btn\" id=\"pick-btn\" onclick=\"pickChar()\">🎭 选择对手</button>\n    <button class=\"go-btn\" id=\"go-btn\" onclick=\"startGame()\">开始 💕</button>\n  </div>\n</div>\n\n<script>\nif(!window.Nuojiji){window.Nuojiji={getUser:async()=>({id:'dev',nickname:'小明',avatar:'',bio:''}),getChar:async()=>({id:'c1',name:'桔梗',avatar:'',description:'温柔害羞的少女，容易脸红',group:''}),getCharList:async()=>[],ai:async()=>({success:false,error:'mock'}),close:()=>{},shareResult:async r=>({shared:false}),pickChars:async()=>{const c=await Nuojiji.getChar();return{picked:!!c,chars:c?[c]:[]}},onGameStateRequest:()=>{}}}\n\nconst ROUNDS=5;\nlet uName='你',uAv='',cInfo=null,cName='角色',cAv='',cDesc='',cPicked=false;\nlet aiHist=[],round=0,uHB=60,cHB=60,started=false,busy=false,ended=false,cid=0;\n\nfunction scroll(){const c=document.getElementById('chat');requestAnimationFrame(()=>c.scrollTop=c.scrollHeight)}\nfunction esc(s){return String(s||'').replace(/[&<>\\\"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\\\"':'&quot;',\"'\":'&#39;'}[c]))}\nfunction setTyp(t){document.getElementById('typing').textContent=t}\n\nfunction updHB(){\n  document.getElementById('u-hb-n').textContent=uHB;\n  document.getElementById('c-hb-n').textContent=cHB;\n  document.getElementById('u-hb-i').style.animationDuration=uHB>=140?'0.25s':uHB>=110?'0.4s':uHB>=80?'0.6s':'0.85s';\n  document.getElementById('c-hb-i').style.animationDuration=cHB>=140?'0.25s':cHB>=110?'0.4s':cHB>=80?'0.6s':'0.85s';\n}\n\nfunction addSys(t){const d=document.createElement('div');d.className='sys';d.textContent=t;document.getElementById('chat').appendChild(d);scroll()}\nfunction addNarr(t){const d=document.createElement('div');d.className='narr';d.textContent=t;document.getElementById('chat').appendChild(d);scroll()}\nfunction addHBLine(uA,cA){\n  const d=document.createElement('div');d.className='hb-line';\n  d.innerHTML=`${esc(uName)} 💗<b>+${uA}</b>→${uHB}　${esc(cName)} 💗<b>+${cA}</b>→${cHB}`;\n  document.getElementById('chat').appendChild(d);scroll();\n}\n\nasync function callAI(sysPrompt, userPrompt){\n  setTyp('……');\n  try{\n    const msgs=[{role:'system',content:sysPrompt}];\n    for(const m of aiHist.slice(-10))msgs.push(m);\n    msgs.push({role:'user',content:userPrompt});\n    const r=await Nuojiji.ai({messages:msgs,maxTokens:400});\n    setTyp('');\n    if(r.success&&r.text){\n      const t=r.text.trim();\n      aiHist.push({role:'user',content:userPrompt},{role:'assistant',content:t});\n      if(aiHist.length>24)aiHist=aiHist.slice(-16);\n      return t;\n    }\n  }catch(e){}\n  setTyp('');\n  return null;\n}\n\nconst SYS_GEN=()=>`你是大冒险游戏的出题者。${uName}和${cName}(${cDesc||'一个角色'})在玩\"谁先心动谁就输\"。\n\n生成3个挑战选项供选择。要求：\n- 每个选项一行，格式：序号. 挑战名称\n- 根据当前轮次调整大胆程度（第1轮温和，后面逐渐大胆）\n- 三个选项全都为色情成人向，且大胆程度有梯度（一个温和、一个中等、一个大胆）\n- 挑战是做的人对另一个人做的事\n- 简短，每个选项不超过10个字`;\n\nconst SYS_NARR=()=>`你是旁白叙述者。${uName}和${cName}(${cDesc||'一个角色'})在玩\"谁先心动谁就输\"的大冒险。\n\n要求：\n- 第三人称，用${uName}和${cName}的名字\n- 只描写动作过程和说出口的话（对话用引号）\n- 不描写内心感受、心理活动、内心独白\n- ${cName}的言行要符合角色性格\n- 200字，描写直白色情，以服务用户为主`;\n\nasync function genChoices(who){\n  const doer=who==='user'?uName:cName;\n  const target=who==='user'?cName:uName;\n  const text=await callAI(SYS_GEN(),\n    `第${round}/${ROUNDS}轮，${doer}的回合。${doer}要对${target}做挑战。请生成3个选项。\\n当前${uName}心跳${uHB}，${cName}心跳${cHB}。`);\n  if(!text)return['对视10秒','拥抱','说情话'];\n  const lines=text.split('\\n').map(l=>l.trim()).filter(Boolean);\n  const opts=[];\n  for(const l of lines){\n    const m=l.match(/^\\d[.、：:\\s]*(.+)/);\n    if(m)opts.push(m[1].trim().slice(0,15));\n    else if(l.length<=15&&!l.startsWith('好')&&!l.startsWith('以下'))opts.push(l);\n    if(opts.length>=3)break;\n  }\n  while(opts.length<3)opts.push(['对视','牵手','拥抱'][opts.length]);\n  return opts;\n}\n\nfunction showCard(opts, who, onPick){\n  const id=++cid;\n  const doer=who==='user'?uName:cName;\n  const d=document.createElement('div');d.className='ch-msg';\n  let btns='';\n  opts.forEach((o,i)=>{btns+=`<button class=\"ch-opt\" id=\"o-${id}-${i}\" onclick=\"window._p${id}(${i})\">${esc(o)}</button>`});\n  d.innerHTML=`<div class=\"ch-card\" id=\"cd-${id}\"><div class=\"ch-who\">${esc(doer)}的回合 · 第${round}/${ROUNDS}轮</div><div class=\"ch-title\">选一个挑战</div><div class=\"ch-opts\" id=\"os-${id}\">${btns}</div></div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  window['_p'+id]=(i)=>{\n    delete window['_p'+id];\n    const el=document.getElementById('os-'+id);\n    if(el)el.innerHTML=`<div class=\"ch-done\">✦ 选了「${esc(opts[i])}」</div>`;\n    onPick(opts[i]);\n  };\n}\n\nasync function userTurn(){\n  if(ended)return;\n  round++;\n  document.getElementById('r-badge').textContent=`${round}/${ROUNDS}`;\n  addSys(`━━ 第${round}轮 · ${uName}的回合 ━━`);\n  setTyp('出题中…');\n  const opts=await genChoices('user');\n  setTyp('');\n  showCard(opts,'user',async(chosen)=>{\n    if(busy)return;busy=true;\n    const text=await callAI(SYS_NARR(),\n      `${uName}选了「${chosen}」对${cName}做。描写${uName}做这件事的动作和说的话，以及${cName}的反应动作和说的话。`);\n    if(text)addNarr(text);\n    const uA=5+Math.floor(Math.random()*8);\n    const cA=10+Math.floor(Math.random()*15);\n    uHB=Math.min(200,uHB+uA);cHB=Math.min(200,cHB+cA);updHB();\n    addHBLine(uA,cA);\n    busy=false;\n    if(round>=ROUNDS){setTimeout(()=>endGame(),600);return}\n    setTimeout(()=>charTurn(),600);\n  });\n}\n\nasync function charTurn(){\n  if(ended)return;\n  addSys(`━━ 第${round}轮 · ${cName}的回合 ━━`);\n  setTyp('出题中…');\n  const opts=await genChoices('char');\n  setTyp('');\n  let chosenIdx=0;\n  try{\n    const r=await callAI(\n      `你是${cName}(${cDesc||'一个角色'})。你在玩\"谁先心动谁就输\"，你要赢。选一个最能让${uName}心动的选项。只回复数字1、2或3。`,\n      `选项：\\n1. ${opts[0]}\\n2. ${opts[1]}\\n3. ${opts[2]}\\n你选哪个？只回复数字。`\n    );\n    if(r){const m=r.match(/[1-3]/);if(m)chosenIdx=parseInt(m[0])-1}\n  }catch(e){}\n  if(chosenIdx<0||chosenIdx>2)chosenIdx=0;\n  const chosen=opts[chosenIdx];\n  const id=++cid;\n  const d=document.createElement('div');d.className='ch-msg';\n  d.innerHTML=`<div class=\"ch-card\"><div class=\"ch-who\">${esc(cName)}的回合 · 第${round}/${ROUNDS}轮</div><div class=\"ch-title\">选一个挑战</div><div class=\"ch-done\">✦ ${esc(cName)}选了「${esc(chosen)}」</div></div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  busy=true;\n  const text=await callAI(SYS_NARR(),\n    `${cName}选了「${chosen}」对${uName}做。描写${cName}做这件事的动作和说的话，以及${uName}的反应动作和说的话。${cName}尽量做得让${uName}心动。`);\n  if(text)addNarr(text);\n  const cA=5+Math.floor(Math.random()*8);\n  const uA=10+Math.floor(Math.random()*15);\n  uHB=Math.min(200,uHB+uA);cHB=Math.min(200,cHB+cA);updHB();\n  addHBLine(uA,cA);\n  busy=false;\n  if(round>=ROUNDS){setTimeout(()=>endGame(),600);return}\n  setTimeout(()=>userTurn(),800);\n}\n\nasync function endGame(){\n  ended=true;\n  addSys('━━ 5轮结束！━━');\n  const draw=uHB===cHB,uWin=uHB<cHB;\n  const winner=draw?null:uWin?uName:cName;\n  const loser=draw?null:uWin?cName:uName;\n  const d=document.createElement('div');\n  d.innerHTML=`<div class=\"res-box\">\n    <div class=\"res-icon\">${draw?'🤝':uWin?'🏆':'💘'}</div>\n    <div class=\"res-title\">${draw?'平局！':esc(winner)+'赢了！'}</div>\n    <div class=\"res-sub\">${draw?'心跳一样…都心动了':esc(loser)+'先心动了 💓'}</div>\n    <div class=\"res-scores\">\n      <div class=\"res-p\"><div class=\"res-p-name\">${esc(uName)}</div><div class=\"res-p-hb\">💗${uHB}</div>\n        <div class=\"res-p-tag ${uHB<=cHB?'w':'l'}\">${uHB<cHB?'😎 冷静':uHB>cHB?'😳 心动':'🤝'}</div></div>\n      <div style=\"font-size:18px;color:var(--text3);align-self:center\">VS</div>\n      <div class=\"res-p\"><div class=\"res-p-name\">${esc(cName)}</div><div class=\"res-p-hb\">💗${cHB}</div>\n        <div class=\"res-p-tag ${cHB<=uHB?'w':'l'}\">${cHB<uHB?'😎 冷静':cHB>uHB?'😳 心动':'🤝'}</div></div>\n    </div>\n    <div class=\"res-btns\">\n      <button class=\"rbtn rbtn-pink\" onclick=\"doShare()\">📤 分享</button>\n      <button class=\"rbtn rbtn-gray\" onclick=\"showStart()\">🔄 再来</button>\n    </div>\n  </div>`;\n  document.getElementById('chat').appendChild(d);scroll();\n  if(draw) await callAI(SYS_NARR(),`五轮结束，${uName}和${cName}心跳一样高（${uHB}），平局。描写两人此刻的动作和说的话。`).then(t=>{if(t)addNarr(t)});\n  else await callAI(SYS_NARR(),`五轮结束，${loser}心跳${loser===uName?uHB:cHB}比${winner}的${winner===uName?uHB:cHB}高——${loser}输了。描写${winner}和${loser}此刻的动作和说的话。`).then(t=>{if(t)addNarr(t)});\n}\n\nasync function pickChar(){\n  try{const r=await Nuojiji.pickChars({min:1,max:1,title:'选择对手'});if(r.picked&&r.chars.length)setChar(r.chars[0])}\n  catch(e){try{const c=await Nuojiji.getChar();if(c)setChar(c)}catch(e2){}}\n}\nfunction setChar(c){\n  cInfo=c;cName=c.name||'角色';cAv=c.avatar||'';cDesc=c.description||'';cPicked=true;\n  document.getElementById('t-c-name').textContent=cName;\n  const sa=(id,av,fb)=>{document.getElementById(id).innerHTML=av?`<img src=\"${av}\">`:esc(fb)};\n  sa('t-c-av',cAv,cName[0]||'?');sa('s-c-av',cAv,cName[0]||'?');\n  document.getElementById('s-cn').textContent=cName;\n  document.getElementById('go-btn').classList.add('show');\n  document.getElementById('pick-btn').textContent=`🎭 重选（${cName}）`;\n}\nasync function startGame(){\n  if(!cPicked)return pickChar();\n  document.getElementById('start-overlay').classList.add('hidden');\n  started=true;ended=false;round=0;uHB=60;cHB=60;aiHist=[];busy=false;cid=0;\n  updHB();document.getElementById('r-badge').textContent=`0/${ROUNDS}`;\n  document.getElementById('chat').innerHTML='';setTyp('');\n  document.getElementById('t-u-name').textContent=uName;\n  addSys('💕 谁先心动谁就输');\n  addSys(`${ROUNDS}轮 · 心跳更高的人输`);\n  setTimeout(()=>userTurn(),300);\n}\nfunction showStart(){\n  document.getElementById('start-overlay').classList.remove('hidden');\n  if(cPicked){document.getElementById('s-cn').textContent=cName;document.getElementById('go-btn').classList.add('show');document.getElementById('pick-btn').textContent=`🎭 重选（${cName}）`}\n}\n\nasync function doShare(){\n  if(!cPicked||round<1)return;\n  const w=uHB<cHB?uName:uHB>cHB?cName:'平局';\n  try{await Nuojiji.shareResult({title:'💕 谁先心动谁就输',summary:`${uName}(💗${uHB}) vs ${cName}(💗${cHB})\\n${w==='平局'?'平局！':w+'赢了！'}`,playerScore:uHB,charScore:cHB,badge:uHB<cHB?'😎 冷静':'💘 心动了',accentColor:'#c4587a',footer:`💕 ${ROUNDS}轮大冒险`})}catch(e){}\n}\n\nif(window.Nuojiji&&Nuojiji.onGameStateRequest)Nuojiji.onGameStateRequest(()=>({round,userHB:uHB,charHB:cHB,opponent:cName}));\n\nasync function loadData(){\n  try{const u=await Nuojiji.getUser().catch(()=>null);if(u){uName=u.nickname||'你';uAv=u.avatar||'';\n    document.getElementById('t-u-name').textContent=uName;\n    if(uAv){document.getElementById('t-u-av').innerHTML=`<img src=\"${uAv}\">`;document.getElementById('s-u-av').innerHTML=`<img src=\"${uAv}\">`}}}catch(e){}\n}\ndocument.addEventListener('DOMContentLoaded',async()=>{await loadData();showStart()});\n</script>\n</body>\n</html>","usesAI":true,"createdAt":1782494334275,"id":1}]